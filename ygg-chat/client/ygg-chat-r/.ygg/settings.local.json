{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .ygg/hooks/inject_branch_point_prompt.py",
            "timeoutMs": 30000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .ygg/hooks/root_note_stop.py",
            "timeoutMs": 60000
          }
        ]
      }
    ]
  }
}
